# Copy this file to .env.local and fill in your keys.
OPENAI_API_KEY=sk-...

# Optional: override the model. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o

# FDE production database — required for Digital Coach analytics.
# Ask the platform team for read-only credentials.
PROD_FDE_DATABASE_HOST=
PROD_FDE_DATABASE_PORT=
PROD_FDE_DATABASE_NAME=taleemabad_core
PROD_FDE_DATABASE_USER=
PROD_FDE_DATABASE_PASSWORD=
